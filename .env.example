# Copy to .env and adjust. All fields marked REQUIRED must be set — the
# server refuses to start if DASH_PASS is missing/weak or SITES is empty.

# --- REQUIRED ---

# Dashboard login. Choose a strong password (min. 12 characters, not
# "change-me"). The server exits with a FATAL error otherwise.
DASH_USER=admin
DASH_PASS=replace-me-with-something-long

# Multi-tenant map: siteKey=origin[,origin2]; siteKey2=...
# The siteKey appears in the ingest URL: https://your-recorder.example/i/<siteKey>
# Only origins listed here can POST events for that key.
# At least one site with at least one origin is required.
SITES=example=https://www.example.com,https://example.com

# --- OPTIONAL ---

# How many days to keep sessions before automatic deletion. Default: 30
RETENTION_DAYS=30

# Per-IP rate limit for ingest (POST /i/:site). Default: 120 req/min
INGEST_RATE_PER_MIN=120

# HTTP port inside the container. Default: 3000
# (Change this only if you don't put a reverse proxy in front.)
PORT=3000

# Data directory (SQLite DB location). Default: /data
# In docker-compose this maps to a named volume or host bind mount.
DATA_DIR=/data
